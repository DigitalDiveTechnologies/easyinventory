@model IEnumerable<EasyInventory.PgData.Entities.Customer>
@{
    ViewBag.Title = "Customers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/custom/downloads/datatables.min.css" rel="stylesheet" />
<script src="~/Content/custom/downloads/datatables.min.js"></script>

@{
    double totalRA = 0;
    double totalPA = 0;
    double raCount = 0;
    double paCount = 0;

    foreach (var item in Model)
    {
        if (item.Balance > 0)
        {
            totalRA += (double)item.Balance;
            raCount += 1;
        }

        if (item.Balance < 0)
        {
            totalPA += (double)item.Balance;
            paCount += 1;
        }
    }
}

<div class="sp-page">
    <section class="sp-hero">
        <div class="sp-hero__icon"><i class="fa fa-users"></i></div>
        <div class="sp-hero__text">
            <h1 class="sp-hero__title">Customers</h1>
            <p class="sp-hero__subtitle">Manage your customer relationships</p>
        </div>
        <div class="sp-hero__actions">
            <a href="/Customers/Create" class="btn btn-primary"><i class="fa fa-plus"></i> Add Customer</a>
        </div>
    </section>

    <div class="sp-stat-grid">
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Total Customers</p>
                <p class="sp-stat-card__value">@Model.Count()</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-user"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Active</p>
                <p class="sp-stat-card__value">@raCount</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-check"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Outstanding</p>
                <p class="sp-stat-card__value">$@totalRA.ToString("0.##")</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-warning"></i></span>
        </div>
    </div>

    <section class="inventory-surface inventory-table-card">
        <div class="inventory-toolbar" style="margin-bottom: 18px;">
            <div>
                <h2 class="inventory-toolbar__title">Customer Directory</h2>
                <p class="inventory-toolbar__subtitle">All customer records with current balance visibility.</p>
            </div>
        </div>

        <table class="table table-hover cell-border" id="CustomerIndex">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Id)</th>
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.Address)</th>
                    <th>@Html.DisplayNameFor(model => model.Balance)</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Id)</td>
                        <td>@Html.DisplayFor(modelItem => item.Name)</td>
                        <td>@Html.DisplayFor(modelItem => item.Address)</td>
                        <td>@Html.DisplayFor(modelItem => item.Balance)</td>
                        <td>
                            @Html.ActionLink("Update", "Edit", new { id = item.Id }, new { @class = "inventory-link-action" })
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr style="font-weight:bold">
                    <td></td>
                    <td></td>
                    <td>@raCount receivables</td>
                    <td>@totalRA.ToString("0.##")</td>
                    <td></td>
                </tr>
                <tr style="font-weight:bold">
                    <td></td>
                    <td></td>
                    <td>@paCount payables</td>
                    <td>@totalPA.ToString("0.##")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </section>
</div>

<script type="text/javascript">
    $(document).ready(function () {
        $('#CustomerIndex').DataTable({
            "scrollY": "400px",
            "scrollCollapse": true,
            "paging": false,
            "bInfo": false,
            "order": [[0, "desc"]],
            "searching": false
        });
    });
</script>
