@{
    var products = Model.Products?.ToList() ?? new List<EasyInventory.PgData.Entities.Product>();
    var totalProducts = products.Count;
    var stockValue = products.Sum(p => p.PurchasePrice * (p.Stock ?? 0));
    var lowStock = products.Count(p => (p.ReOrder ?? 0) > 0 && (p.Stock ?? 0) <= p.ReOrder);
    var outOfStock = products.Count(p => (p.Stock ?? 0) <= 0);
}


<input type="hidden" name="supplierId" id="supplierId" value="@ViewBag.SupplierId" />
@*<h1>@ViewBag.myLog</h1>*@



@*<p>
        @Html.ActionLink("Create New Sale Order", "Create")
