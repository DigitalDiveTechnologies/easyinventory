<div class="sp-page">
    <section class="sp-hero">
        <div class="sp-hero__icon"><i class="fa fa-cube"></i></div>
        <div class="sp-hero__text">
            <h1 class="sp-hero__title">Stock Management</h1>
            <p class="sp-hero__subtitle">Monitor inventory levels and value</p>
        </div>
        <div class="sp-hero__actions">
            <a href="#" id="printMe" class="btn btn-primary"><i class="fa fa-download"></i> Export</a>
        </div>
    </section>

    <div class="sp-stat-grid">
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Total Products</p>
                <p class="sp-stat-card__value">@totalProducts</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-cube"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Stock Value</p>
                <p class="sp-stat-card__value">$@stockValue.ToString("0.##")</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-dollar"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Low Stock</p>
                <p class="sp-stat-card__value">@lowStock</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-warning"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Out of Stock</p>
                <p class="sp-stat-card__value">@outOfStock</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-ban"></i></span>
        </div>
    </div>

    <form name="registration_form_Product" id="registration_form_Product" class="sp-filter noPrint">
        <input type="hidden" name="SaleOrder.CustomerId" id="idnCustomer" value="@ViewBag.CustomerId" />
        <input type="hidden" autocomplete="off" class="form-control" name="Customer.Name" id="customer" value="" placeholder="Search by customer" data-toggle="tooltip" data-placement="top" title="Search by customer">
        <span class="sp-filter__icon"><i class="fa fa-search"></i></span>
        <div class="sp-filter__field">
            @Html.Editor("startDate", new { htmlAttributes = new { @class = "form-control datepicker", @id = "datepickerStart", @placeholder = "Start date", @Value = ViewBag.StartDate } })
        </div>
        <div class="sp-filter__field">
            @Html.Editor("endDate", new { htmlAttributes = new { @class = "form-control datepicker", @id = "datepickerEnd", @placeholder = "End date", @Value = ViewBag.EndDate } })
        </div>
        <button type="button" id="btnSearch" class="btn btn-primary"><i class="fa fa-filter"></i> Filter</button>
    </form>

    @*<input type="button" onclick="printDiv('print-content')" value="print a div!" />*@
    @*<button onclick="myFunction()">Print this page</button>*@

</div>

@{Html.RenderPartial("_Summary", Model); }

