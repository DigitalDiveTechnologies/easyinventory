@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using EasyInventory.PgData.Entities
@{
    var recentSales = ViewBag.RecentSales as List<SO> ?? new List<SO>();
    var lowStockProducts = ViewBag.LowStockProducts as List<Product> ?? new List<Product>();
}

<div class="sp-page">
    <section class="sp-hero">
        <div class="sp-hero__icon"><i class="fa fa-line-chart"></i></div>
        <div class="sp-hero__text">
            <h1 class="sp-hero__title">Dashboard</h1>
            <p class="sp-hero__subtitle">Welcome back! Here's your business overview</p>
        </div>
        <div class="sp-hero__actions">
            <a href="/SOSR/Create?IsReturn=false" class="btn btn-primary"><i class="fa fa-plus"></i> New Sale</a>
        </div>
    </section>

    <div class="sp-stat-grid">
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Total Sales</p>
                <p class="sp-stat-card__value">$@(((decimal)ViewBag.SOAmount).ToString("0.##"))</p>
                <div class="sp-stat-card__delta sp-stat-card__delta--muted">Current total</div>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-dollar"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Total Purchases</p>
                <p class="sp-stat-card__value">$@(((decimal)ViewBag.POAmount).ToString("0.##"))</p>
                <div class="sp-stat-card__delta sp-stat-card__delta--muted">Current total</div>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-credit-card"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Total Profit</p>
                <p class="sp-stat-card__value">$@(((decimal)ViewBag.Profit).ToString("0.##"))</p>
                <div class="sp-stat-card__delta sp-stat-card__delta--muted">Net from completed sales</div>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-line-chart"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Total Products</p>
                <p class="sp-stat-card__value">@ViewBag.Products</p>
                <div class="sp-stat-card__delta sp-stat-card__delta--muted">Active catalog items</div>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-cube"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Low Stock Items</p>
                <p class="sp-stat-card__value">@(((int)ViewBag.LowStockCount).ToString("0"))</p>
                <div class="sp-stat-card__delta sp-stat-card__delta--warning">Requires attention</div>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-warning"></i></span>
        </div>
    </div>

    <section class="sp-section-grid">
        <div class="sp-panel">
            <div class="inventory-toolbar">
                <div>
                    <p class="sp-panel__title">Recent Sales</p>
                    <p class="sp-panel__subtitle">Latest sales transactions</p>
                </div>
                <a href="/SOSR/Index" class="inventory-link-action">View all</a>
            </div>
            <div class="sp-list">
                @if (recentSales.Count == 0)
                {
                    <div class="sp-list-item">
                        <div class="sp-list-item__meta">
                            <span class="sp-list-badge"><i class="fa fa-info"></i></span>
                            <div>
                                <div>No sales recorded yet</div>
                                <div class="inventory-table-meta">Create a new sale to get started</div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    var index = 1;
                    foreach (var sale in recentSales)
                    {
                        var customerName = sale.Customer?.Name ?? "Walk-in Customer";
                        var amount = sale.BillAmount;
                        var balance = sale.Balance ?? (sale.BillAmount - sale.BillPaid);
                        var status = balance <= 0 ? "Paid" : (sale.BillPaid > 0 ? "Partial" : "Pending");
                        var pillClass = status == "Paid" ? "sp-pill" : "sp-pill sp-pill--warning";
                        <div class="sp-list-item">
                            <div class="sp-list-item__meta">
                                <span class="sp-list-badge">@index.ToString("00")</span>
                                <div>
                                    <div>@customerName</div>
                                    <div class="inventory-table-meta">#@sale.Id</div>
                                </div>
                            </div>
                            <div>
                                <div style="font-weight:700">$@amount.ToString("0.00")</div>
                                <span class="@pillClass">@status</span>
                            </div>
                        </div>
                        index++;
                    }
                }
            </div>
        </div>

        <div class="sp-panel">
            <div class="inventory-toolbar">
                <div>
                    <p class="sp-panel__title">Low Stock Alert</p>
                    <p class="sp-panel__subtitle">Products running low</p>
                </div>
                <a href="/StockTransections/Summary" class="inventory-link-action">View all</a>
            </div>
            <div class="sp-list">
                @if (lowStockProducts.Count == 0)
                {
                    <div class="sp-list-item">
                        <div class="sp-list-item__meta">
                            <span class="sp-list-badge"><i class="fa fa-check"></i></span>
                            <div>
                                <div>All products are above reorder level</div>
                                <div class="inventory-table-meta">No low stock alerts</div>
                            </div>
                        </div>
                        <span class="sp-pill">Stable</span>
                    </div>
                }
                else
                {
                    foreach (var product in lowStockProducts)
                    {
                        var stockValue = product.Stock ?? 0;
                        var reorder = product.ReOrder ?? 0;
                        var status = stockValue <= 0 ? "Out" : (reorder > 0 && stockValue <= reorder * 0.5m ? "Critical" : "Low");
                        var pillClass = status == "Low" ? "sp-pill sp-pill--warning" : "sp-pill sp-pill--danger";
                        <div class="sp-list-item">
                            <div class="sp-list-item__meta">
                                <span class="sp-list-badge"><i class="fa fa-cube"></i></span>
                                <div>
                                    <div>@(product.Name ?? "Unnamed Product")</div>
                                    <div class="inventory-table-meta">@stockValue.ToString("0") units left</div>
                                </div>
                            </div>
                            <span class="@pillClass">@status</span>
                        </div>
                    }
                }
            </div>
        </div>
    </section>
</div>
