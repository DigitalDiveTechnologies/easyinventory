@model IEnumerable<EasyInventory.PgData.Entities.Supplier>
@{
    ViewBag.Title = "Suppliers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/Content/custom/downloads/datatables.min.css" rel="stylesheet" />
<script src="~/Content/custom/downloads/datatables.min.js"></script>

@{
    decimal totalReceivables = 0;
    decimal totalPayables = 0;
    decimal receivableCount = 0;
    decimal payableCount = 0;

    foreach (var item in Model)
    {
        if (item.Balance > 0)
        {
            totalPayables += (decimal)item.Balance;
            payableCount += 1;
        }

        if (item.Balance < 0)
        {
            totalReceivables += (decimal)item.Balance;
            receivableCount += 1;
        }
    }
}

<div class="sp-page">
    <section class="sp-hero">
        <div class="sp-hero__icon"><i class="fa fa-truck"></i></div>
        <div class="sp-hero__text">
            <h1 class="sp-hero__title">Suppliers</h1>
            <p class="sp-hero__subtitle">Manage your supplier relationships</p>
        </div>
        <div class="sp-hero__actions">
            <a href="/Suppliers/Create" id="createSupplier" class="btn btn-primary"><i class="fa fa-plus"></i> Add Supplier</a>
        </div>
    </section>

    <div class="sp-stat-grid">
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Total Suppliers</p>
                <p class="sp-stat-card__value">@Model.Count()</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-building"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Active This Month</p>
                <p class="sp-stat-card__value">@receivableCount</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-calendar"></i></span>
        </div>
        <div class="sp-stat-card">
            <div>
                <p class="sp-stat-card__label">Total Payable</p>
                <p class="sp-stat-card__value">$@totalPayables.ToString("0.##")</p>
            </div>
            <span class="sp-stat-card__icon"><i class="fa fa-warning"></i></span>
        </div>
    </div>

    <section class="inventory-surface inventory-table-card">
        <div class="inventory-toolbar" style="margin-bottom: 18px;">
            <div>
                <h2 class="inventory-toolbar__title">Supplier Directory</h2>
                <p class="inventory-toolbar__subtitle">Every vendor record with current balance visibility and quick update access.</p>
            </div>
        </div>

        <table class="table table-hover cell-border" id="SupplierIndex">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Id)</th>
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.Address)</th>
                    <th>@Html.DisplayNameFor(model => model.Balance)</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Id)</td>
                        <td>@Html.DisplayFor(modelItem => item.Name)</td>
                        <td>@Html.DisplayFor(modelItem => item.Address)</td>
                        <td>@Html.DisplayFor(modelItem => item.Balance)</td>
                        <td>
                            @Html.ActionLink("Update", "Edit", new { id = item.Id }, new { @class = "inventory-link-action" })
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr style="font-weight:bold">
                    <td></td>
                    <td></td>
                    <td>@receivableCount receivables</td>
                    <td>@totalReceivables.ToString("0.##")</td>
                    <td></td>
                </tr>
                <tr style="font-weight:bold">
                    <td></td>
                    <td></td>
                    <td>@payableCount payables</td>
                    <td>@totalPayables.ToString("0.##")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </section>
</div>

<script type="text/javascript">
    $(document).ready(function () {
        $('#SupplierIndex').DataTable({
            "scrollY": "400px",
            "scrollCollapse": true,
            "paging": false,
            "bInfo": false,
            "order": [[0, "asc"]],
            "searching": false
        });
    });
</script>
